{
  "name": "agenticode",
  "version": "1.0.0",
  "description": "The most feature-rich open source AI coding agent",
  "type": "module",
  "bin": {
    "agenticode": "./src/entrypoints/cli.tsx"
  },
  "scripts": {
    "dev": "bun run src/entrypoints/cli.tsx",
    "build": "bun run scripts/build.ts",
    "build:all": "bun run scripts/build.ts --platform linux --arch x64 && bun run scripts/build.ts --platform linux --arch arm64 && bun run scripts/build.ts --platform darwin --arch arm64 && bun run scripts/build.ts --platform darwin --arch x64 && bun run scripts/build.ts --platform windows --arch x64",
    "start": "bun run src/entrypoints/cli.tsx",
    "typecheck": "tsc --noEmit"
  },
